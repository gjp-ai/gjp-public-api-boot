				{
					"name": "Get All App Settings",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/app-settings",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "app-settings"]
						}
					}
				}
			]
		},
		{
			"name": "Articles",
			"item": [
				{
					"name": "Get Articles",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/articles?page=0&size=20&sort=displayOrder&direction=asc",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "articles"],
							"query": [
								{ "key": "title", "value": "", "disabled": true },
								{ "key": "lang", "value": "", "description": "EN or ZH", "disabled": true },
								{ "key": "tags", "value": "", "disabled": true },
								{ "key": "isActive", "value": "true", "disabled": true },
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "20" },
								{ "key": "sort", "value": "displayOrder" },
								{ "key": "direction", "value": "asc" }
							]
						}
					}
				},
				{
					"name": "Get Article By ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/articles/{{id}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "articles", "{{id}}"]
						}
					}
				}
			]
		},
